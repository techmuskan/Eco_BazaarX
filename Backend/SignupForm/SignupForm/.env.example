# Backend server port
SERVER_PORT=8080

# Production MySQL connection
DB_URL=jdbc:mysql://your-mysql-host:3306/LoginDetails?useSSL=true&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
JPA_DDL_AUTO=update

# Mail / OTP settings
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Frontend origins allowed to call the backend
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173
APP_PUBLIC_BASE_URL=http://localhost:8080

# JWT secret must be long and random in production
APP_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
APP_JWT_EXPIRATION_MS=7200000

# Keep disabled after first admin setup unless intentionally needed
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_NAME=EcoBazaar Admin
BOOTSTRAP_ADMIN_EMAIL=admin@ecobazar.local
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_ADMIN_PHONE=9999999999

# Keep false in production unless you explicitly want open admin signup
APP_SIGNUP_ADMIN_ENABLED=false
